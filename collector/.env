# -------------------------
# Postgres
# -------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agri_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SCHEMA=public

# -------------------------
# RabbitMQ
# -------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=wineapp
RABBITMQ_PASSWORD=wineapp
RABBITMQ_EXCHANGE=agri.events

# -------------------------
# External API
# -------------------------
WINE_API_BASE_URL=https://ec.europa.eu/agrifood/api/wine
REQUEST_TIMEOUT=60